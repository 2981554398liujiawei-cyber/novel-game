{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "quests"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "quests": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "required": [
          "quest_id",
          "depends_on"
        ],
        "properties": {
          "quest_id": {
            "type": "string",
            "pattern": "^[A-Z][A-Z0-9_]+$"
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string",
              "pattern": "^[A-Z][A-Z0-9_]+$"
            },
            "uniqueItems": true
          },
          "gate": {
            "type": "object",
            "required": [
              "operator",
              "conditions"
            ],
            "properties": {
              "operator": {
                "enum": [
                  "and",
                  "or"
                ]
              },
              "conditions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "key",
                    "op",
                    "value"
                  ],
                  "properties": {
                    "key": {
                      "type": "string",
                      "pattern": "^[a-z][a-z0-9_.]+$"
                    },
                    "op": {
                      "enum": [
                        "eq",
                        "ne",
                        "neq",
                        "gte",
                        "lte",
                        "gt",
                        "lt",
                        "in",
                        "not_in"
                      ]
                    },
                    "value": {}
                  }
                }
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
