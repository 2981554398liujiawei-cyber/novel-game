{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StoryChapterMapping",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "region_id", "coverage_status", "source_chapters", "mappings"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "region_id": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]+$"},
    "coverage_status": {"enum": ["FRAMEWORK_ONLY", "COMPLETE"]},
    "source_chapters": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
    "mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["chapter_id", "classification", "task_ids", "note"],
        "properties": {
          "chapter_id": {"type": "string", "minLength": 1},
          "classification": {"enum": ["KEEP_GAME", "MERGE_GAME", "MIGRATE_REALITY", "DROP"]},
          "task_ids": {"type": "array", "uniqueItems": true, "items": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]+$"}},
          "note": {"type": "string"}
        }
      }
    }
  }
}
