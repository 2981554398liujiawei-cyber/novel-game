{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LocationRegistry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "locations"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "locations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "location_id",
          "name",
          "background_id",
          "music_id",
          "connections",
          "unlock_conditions"
        ],
        "properties": {
          "location_id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "background_id": {
            "type": "string"
          },
          "music_id": {
            "type": "string"
          },
          "connections": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "unlock_conditions": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "key",
                "op",
                "value"
              ],
              "properties": {
                "key": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_.]+$"
                },
                "op": {
                  "enum": [
                    "eq",
                    "ne",
                    "gte",
                    "lte",
                    "gt",
                    "lt",
                    "in"
                  ]
                },
                "value": {}
              }
            }
          }
        }
      }
    }
  }
}
