{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "StateRegistry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "states"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "states": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "key",
          "type",
          "default",
          "persistent",
          "writers",
          "readers"
        ],
        "properties": {
          "key": {
            "type": "string"
          },
          "type": {
            "enum": [
              "string",
              "integer",
              "number",
              "boolean"
            ]
          },
          "default": {},
          "allowed": {
            "type": "array"
          },
          "min": {
            "type": "number"
          },
          "max": {
            "type": "number"
          },
          "persistent": {
            "type": "boolean"
          },
          "writers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "readers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
