{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DevelopmentSaveV1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "save_version",
    "game_version",
    "development_save",
    "created_at",
    "updated_at",
    "slot_id",
    "playtime_seconds",
    "current_story_id",
    "current_story_node_id",
    "game_state",
    "random_state"
  ],
  "properties": {
    "schema_version": {
      "enum": [
        "1.0.0",
        "1.1.0"
      ]
    },
    "save_version": {
      "type": "integer",
      "minimum": 1
    },
    "game_version": {
      "type": "string",
      "minLength": 1
    },
    "development_save": {
      "const": true
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string",
      "minLength": 1
    },
    "slot_id": {
      "enum": [
        "manual_1",
        "manual_2",
        "manual_3",
        "auto",
        "quick"
      ]
    },
    "playtime_seconds": {
      "type": "number",
      "minimum": 0
    },
    "current_story_id": {
      "type": "string",
      "minLength": 1
    },
    "current_story_node_id": {
      "type": "string",
      "minLength": 1
    },
    "game_state": {
      "type": "object"
    },
    "inventory_state": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "snapshot_version",
        "capacity",
        "backpack",
        "quest_items",
        "equipment",
        "custody"
      ],
      "properties": {
        "snapshot_version": {
          "const": 1
        },
        "capacity": {
          "type": "integer",
          "minimum": 1
        },
        "backpack": {
          "type": "array"
        },
        "quest_items": {
          "type": "array"
        },
        "equipment": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "weapon",
            "off_hand",
            "head",
            "body",
            "accessory_1",
            "accessory_2"
          ],
          "properties": {
            "weapon": {
              "type": [
                "object",
                "null"
              ]
            },
            "off_hand": {
              "type": [
                "object",
                "null"
              ]
            },
            "head": {
              "type": [
                "object",
                "null"
              ]
            },
            "body": {
              "type": [
                "object",
                "null"
              ]
            },
            "accessory_1": {
              "type": [
                "object",
                "null"
              ]
            },
            "accessory_2": {
              "type": [
                "object",
                "null"
              ]
            }
          }
        },
        "custody": {
          "type": "array"
        }
      }
    },
    "random_state": {
      "type": "object",
      "required": [
        "seed"
      ],
      "properties": {
        "seed": {
          "type": "integer"
        }
      },
      "additionalProperties": true
    }
  }
}
