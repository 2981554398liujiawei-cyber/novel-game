{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.wangzhe/schemas/quest.schema.json",
  "title": "WangZheQuestV13",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "quest_id",
    "content_status",
    "title",
    "region_id",
    "category",
    "design",
    "prerequisites",
    "mutual_exclusions",
    "trigger",
    "scenes",
    "entry_node",
    "nodes",
    "mechanics",
    "branch_summary",
    "continuations",
    "rewards",
    "world_changes",
    "post_quest_feedback",
    "implementation",
    "allowed_loops",
    "test_cases"
  ],
  "$defs": {
    "questAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["action", "quest_id"],
      "properties": {
        "action": {"enum": ["activate", "update_objective", "set_qualified", "complete", "fail", "suspend", "resume", "reopen"]},
        "quest_id": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]+$"},
        "objective_id": {"type": "string", "minLength": 1},
        "update": {"type": "object"},
        "continuation_id": {"type": "string"}
      },
      "allOf": [
        {
          "if": {"properties": {"action": {"const": "update_objective"}}, "required": ["action"]},
          "then": {"required": ["objective_id", "update"]}
        },
        {
          "if": {"properties": {"action": {"const": "fail"}}, "required": ["action"]},
          "then": {"required": ["continuation_id"]}
        }
      ]
    },
    "relationshipAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relationship_id", "dimension", "op", "value"],
      "properties": {
        "relationship_id": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]+$"},
        "dimension": {"enum": ["trust", "affection", "respect", "tension"]},
        "op": {"enum": ["set", "inc", "dec"]},
        "value": {"type": "number"}
      }
    },
    "rewardItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["item_id", "quantity"],
      "properties": {
        "item_id": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]+$"},
        "quantity": {"type": "integer", "minimum": 1}
      }
    }
  },
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "quest_id": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]+$"
    },
    "content_status": {
      "enum": [
        "outline",
        "design_card",
        "draft_script",
        "complete_script",
        "data_ready",
        "implemented",
        "verified"
      ]
    },
    "title": {
      "type": "string"
    },
    "region_id": {
      "type": "string"
    },
    "category": {
      "enum": [
        "main",
        "side",
        "relationship",
        "encounter",
        "hidden"
      ]
    },
    "source_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "design": {
      "type": "object",
      "minProperties": 10
    },
    "prerequisites": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "key",
          "op",
          "value"
        ],
        "properties": {
          "key": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_.]+$"
          },
          "op": {
            "enum": [
              "eq",
              "ne",
              "neq",
              "gte",
              "lte",
              "gt",
              "lt",
              "in",
              "not_in"
            ]
          },
          "value": {}
        }
      }
    },
    "mutual_exclusions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "trigger": {
      "type": "object",
      "required": [
        "method",
        "location_id",
        "conditions",
        "opening_presentation"
      ],
      "properties": {
        "method": {
          "type": "string"
        },
        "location_id": {
          "type": "string"
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "key",
              "op",
              "value"
            ],
            "properties": {
              "key": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_.]+$"
              },
              "op": {
                "enum": [
                  "eq",
                  "ne",
                  "neq",
                  "gte",
                  "lte",
                  "gt",
                  "lt",
                  "in",
                  "not_in"
                ]
              },
              "value": {}
            }
          }
        },
        "opening_presentation": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "scene_id",
          "title",
          "entry_nodes",
          "exit_nodes",
          "participant_ids",
          "objective",
          "optional_interactions"
        ],
        "properties": {
          "scene_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "entry_nodes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "exit_nodes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "participant_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "objective": {
            "type": "string"
          },
          "optional_interactions": {
            "type": "array"
          }
        },
        "additionalProperties": false
      }
    },
    "entry_node": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "node_id",
          "type",
          "location_id",
          "scene_id",
          "purpose"
        ],
        "properties": {
          "node_id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9_]{1,63}$"
          },
          "type": {
            "enum": [
              "narrative",
              "dialogue",
              "choice",
              "combat",
              "reward",
              "complete"
            ]
          },
          "location_id": {
            "type": "string"
          },
          "scene_id": {
            "type": "string"
          },
          "purpose": {
            "type": "string"
          },
          "text": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "next": {
            "type": "string"
          },
          "effects": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "key",
                "op",
                "value"
              ],
              "properties": {
                "key": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_.]+$"
                },
                "op": {
                  "enum": [
                    "set",
                    "inc",
                    "dec"
                  ]
                },
                "value": {}
              }
            }
          },
          "conditions": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "key",
                "op",
                "value"
              ],
              "properties": {
                "key": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_.]+$"
                },
                "op": {
                  "enum": [
                    "eq",
                    "ne",
                    "neq",
                    "gte",
                    "lte",
                    "gt",
                    "lt",
                    "in",
                    "not_in"
                  ]
                },
                "value": {}
              }
            }
          },
          "speaker_id": {
            "type": "string"
          },
          "expression": {
            "type": "string"
          },
          "portrait_action": {
            "enum": [
              "show",
              "keep",
              "hide",
              "replace"
            ]
          },
          "gesture": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "camera": {
            "type": "string"
          },
          "delivery": {
            "type": "string"
          },
          "choices": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "choice_id",
                "text",
                "intent",
                "protagonist_boundary",
                "visible_risk",
                "consequence_summary",
                "hidden_consequence",
                "goto"
              ],
              "properties": {
                "choice_id": {
                  "type": "string"
                },
                "text": {
                  "type": "string",
                  "minLength": 1
                },
                "locked_text": {
                  "type": "string"
                },
                "intent": {
                  "type": "string"
                },
                "protagonist_boundary": {
                  "const": "allowed"
                },
                "visible_risk": {
                  "type": "string"
                },
                "consequence_summary": {
                  "type": "string"
                },
                "hidden_consequence": {
                  "type": "string"
                },
                "goto": {
                  "type": "string"
                },
                "conditions": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "key",
                      "op",
                      "value"
                    ],
                    "properties": {
                      "key": {
                        "type": "string",
                        "pattern": "^[a-z][a-z0-9_.]+$"
                      },
                      "op": {
                        "enum": [
                          "eq",
                          "ne",
                          "neq",
                          "gte",
                          "lte",
                          "gt",
                          "lt",
                          "in",
                          "not_in"
                        ]
                      },
                      "value": {}
                    }
                  }
                },
                "effects": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "key",
                      "op",
                      "value"
                    ],
                    "properties": {
                      "key": {
                        "type": "string",
                        "pattern": "^[a-z][a-z0-9_.]+$"
                      },
                      "op": {
                        "enum": [
                          "set",
                          "inc",
                          "dec"
                        ]
                      },
                      "value": {}
                    }
                  }
                },
                "quest_actions": {
                  "type": "array",
                  "items": {"$ref": "#/$defs/questAction"}
                },
                "relationship_actions": {
                  "type": "array",
                  "items": {"$ref": "#/$defs/relationshipAction"}
                },
                "hidden_when_locked": {
                  "type": "boolean"
                }
              }
            }
          },
          "combat_ref": {
            "type": "string"
          },
          "reward_item_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "reward_items": {
            "type": "array",
            "items": {"$ref": "#/$defs/rewardItem"}
          },
          "quest_actions": {
            "type": "array",
            "items": {"$ref": "#/$defs/questAction"}
          },
          "relationship_actions": {
            "type": "array",
            "items": {"$ref": "#/$defs/relationshipAction"}
          },
          "terminal": {
            "type": "boolean"
          },
          "outcome": {
            "type": "string"
          },
          "next_on_win": {
            "type": "string"
          },
          "next_on_loss": {
            "type": "string"
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "type": {
                  "const": "dialogue"
                }
              }
            },
            "then": {
              "required": [
                "speaker_id",
                "text",
                "expression",
                "portrait_action",
                "next"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "type": {
                  "const": "choice"
                }
              }
            },
            "then": {
              "required": [
                "choices"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "type": {
                  "const": "combat"
                }
              }
            },
            "then": {
              "required": [
                "combat_ref",
                "next_on_win",
                "next_on_loss"
              ]
            }
          },
          {
            "if": {
              "properties": {
                "type": {
                  "const": "complete"
                }
              }
            },
            "then": {
              "required": [
                "terminal",
                "outcome"
              ]
            }
          }
        ]
      }
    },
    "mechanics": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "branch_summary": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "continuations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "rewards": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "oneOf": [
          {
            "additionalProperties": false,
            "required": [
              "type",
              "reward_id"
            ],
            "properties": {
              "type": {
                "const": "signal_only"
              },
              "reward_id": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          {
            "additionalProperties": false,
            "required": [
              "type",
              "reward_id",
              "items"
            ],
            "properties": {
              "type": {
                "const": "items"
              },
              "reward_id": {
                "type": "string",
                "minLength": 1
              },
              "items": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "item_id",
                    "quantity"
                  ],
                  "properties": {
                    "item_id": {
                      "type": "string",
                      "pattern": "^[A-Z][A-Z0-9_]+$"
                    },
                    "quantity": {
                      "type": "integer",
                      "minimum": 1
                    }
                  }
                }
              }
            }
          }
        ]
      }
    },
    "world_changes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "post_quest_feedback": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    },
    "implementation": {
      "type": "object",
      "minProperties": 5
    },
    "allowed_loops": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "loop_id",
          "node_ids",
          "max_recommended_repeats",
          "has_exit"
        ],
        "properties": {
          "loop_id": {
            "type": "string"
          },
          "node_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "max_recommended_repeats": {
            "type": "integer",
            "minimum": 1
          },
          "has_exit": {
            "const": true
          }
        },
        "additionalProperties": false
      }
    },
    "test_cases": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": [
          "test_id",
          "initial_state",
          "steps",
          "expected"
        ],
        "properties": {
          "test_id": {
            "type": "string"
          },
          "initial_state": {
            "type": "object"
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "expected": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status_state_key",
        "reward_granted_state_key",
        "availability",
        "objectives",
        "completion_mode",
        "failure"
      ],
      "properties": {
        "status_state_key": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.]+$"
        },
        "reward_granted_state_key": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_.]+$"
        },
        "availability": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "all",
            "any"
          ],
          "properties": {
            "all": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "kind",
                  "op",
                  "value"
                ],
                "properties": {
                  "kind": {
                    "enum": [
                      "state",
                      "quest"
                    ]
                  },
                  "key": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_.]+$"
                  },
                  "quest_id": {
                    "type": "string",
                    "pattern": "^[A-Z][A-Z0-9_]+$"
                  },
                  "op": {
                    "enum": [
                      "eq",
                      "ne",
                      "neq",
                      "gte",
                      "lte",
                      "gt",
                      "lt",
                      "in",
                      "not_in"
                    ]
                  },
                  "value": {}
                },
                "allOf": [
                  {
                    "if": {
                      "properties": {
                        "kind": {
                          "const": "state"
                        }
                      }
                    },
                    "then": {
                      "required": [
                        "key"
                      ]
                    }
                  },
                  {
                    "if": {
                      "properties": {
                        "kind": {
                          "const": "quest"
                        }
                      }
                    },
                    "then": {
                      "required": [
                        "quest_id"
                      ]
                    }
                  }
                ]
              }
            },
            "any": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "kind",
                  "op",
                  "value"
                ],
                "properties": {
                  "kind": {
                    "enum": [
                      "state",
                      "quest"
                    ]
                  },
                  "key": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_.]+$"
                  },
                  "quest_id": {
                    "type": "string",
                    "pattern": "^[A-Z][A-Z0-9_]+$"
                  },
                  "op": {
                    "enum": [
                      "eq",
                      "ne",
                      "neq",
                      "gte",
                      "lte",
                      "gt",
                      "lt",
                      "in",
                      "not_in"
                    ]
                  },
                  "value": {}
                },
                "allOf": [
                  {
                    "if": {
                      "properties": {
                        "kind": {
                          "const": "state"
                        }
                      }
                    },
                    "then": {
                      "required": [
                        "key"
                      ]
                    }
                  },
                  {
                    "if": {
                      "properties": {
                        "kind": {
                          "const": "quest"
                        }
                      }
                    },
                    "then": {
                      "required": [
                        "quest_id"
                      ]
                    }
                  }
                ]
              }
            }
          }
        },
        "objectives": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "objective_id",
              "type",
              "required"
            ],
            "properties": {
              "objective_id": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_]{1,63}$"
              },
              "type": {
                "enum": [
                  "boolean",
                  "counter",
                  "collection",
                  "combat_result",
                  "state_condition"
                ]
              },
              "required": {
                "type": "boolean"
              },
              "progress_state_key": {
                "type": "string",
                "pattern": "^[a-z][a-z0-9_.]+$"
              },
              "target": {},
              "allowed_results": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "uniqueItems": true
              },
              "condition": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "key",
                  "op",
                  "value"
                ],
                "properties": {
                  "key": {
                    "type": "string",
                    "pattern": "^[a-z][a-z0-9_.]+$"
                  },
                  "op": {
                    "enum": [
                      "eq",
                      "ne",
                      "neq",
                      "gte",
                      "lte",
                      "gt",
                      "lt",
                      "in",
                      "not_in"
                    ]
                  },
                  "value": {}
                }
              }
            },
            "allOf": [
              {
                "if": {
                  "properties": {
                    "type": {
                      "const": "state_condition"
                    }
                  }
                },
                "then": {
                  "required": [
                    "condition"
                  ]
                },
                "else": {
                  "required": [
                    "progress_state_key",
                    "target"
                  ]
                }
              }
            ]
          }
        },
        "qualification": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "objective_ids",
            "required_count"
          ],
          "properties": {
            "objective_ids": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string"
              },
              "uniqueItems": true
            },
            "required_count": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "completion_mode": {
          "enum": [
            "automatic",
            "manual"
          ]
        },
        "failure": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "continuation_state_key",
            "allowed_continuations",
            "resume_from_failed",
            "resume_from_suspended",
            "reopen_allowed"
          ],
          "properties": {
            "continuation_state_key": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_.]+$"
            },
            "allowed_continuations": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              },
              "uniqueItems": true
            },
            "resume_from_failed": {
              "enum": [
                "available",
                "active"
              ]
            },
            "resume_from_suspended": {
              "enum": [
                "available",
                "active"
              ]
            },
            "reopen_allowed": {
              "type": "boolean"
            }
          }
        }
      }
    }
  }
}
