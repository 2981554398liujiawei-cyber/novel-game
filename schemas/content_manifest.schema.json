{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schema_version",
    "manifest_version",
    "content_files",
    "planned_content",
    "forbidden_path_fragments",
    "hash_algorithm"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "manifest_version": {
      "type": "integer"
    },
    "content_files": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "planned_content": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["content_id", "region_id", "status", "path"],
        "properties": {
          "content_id": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]+$"},
          "region_id": {"type": "string", "pattern": "^[A-Z][A-Z0-9_]+$"},
          "status": {"enum": ["not_loaded", "data_ready", "implemented", "verified"]},
          "path": {"type": ["string", "null"]}
        },
        "allOf": [
          {
            "if": {"properties": {"status": {"const": "not_loaded"}}},
            "then": {"properties": {"path": {"type": "null"}}},
            "else": {"properties": {"path": {"type": "string", "pattern": "^quests/.+\\.json$"}}}
          }
        ]
      }
    },
    "forbidden_path_fragments": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "hash_algorithm": {
      "const": "sha256"
    },
    "entry_story_id": {
      "type": ["string", "null"],
      "pattern": "^[A-Z][A-Z0-9_]+$"
    }
  },
  "additionalProperties": false
}
