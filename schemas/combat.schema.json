{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CombatRegistry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "combats"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "combats": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "combat_id",
          "location_id",
          "enemy_ids",
          "ally_ids",
          "victory",
          "defeat",
          "retreat",
          "unique_mechanic",
          "phases"
        ],
        "properties": {
          "combat_id": {
            "type": "string"
          },
          "location_id": {
            "type": "string"
          },
          "enemy_ids": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "ally_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "victory": {
            "type": "object"
          },
          "defeat": {
            "type": "object"
          },
          "retreat": {
            "type": "object",
            "required": [
              "allowed",
              "continuation_id"
            ]
          },
          "unique_mechanic": {
            "type": "string"
          },
          "phases": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "items": {
              "type": "object"
            }
          }
        }
      }
    }
  }
}
